programa {
  funcao inicio() {
    // Dados de um usuário (nome, idade, altura, genero, programador)
    cadeia nome = "Lucas"
    inteiro idade = 17
    real altura = 1.75
    caracter genero = 'M'
    logico programador = verdadeiro
    // Nome: Lucas

    escreva("Nome:", nome,"\n")
    escreva("Idade:", idade, "\n")
    escreva("Altura:", altura, "\n")
    escreva("Gênero:", genero, "\n")
    escreva("Programador:", programador, "\n")
  }
}
